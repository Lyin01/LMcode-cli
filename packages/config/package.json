{
  "name": "@lmcode-cli/config",
  "version": "0.7.1",
  "private": true,
  "description": "Platform configuration and model management for LMcode",
  "license": "MIT",
  "author": "LMcode",
  "homepage": "https://github.com/Lyin01/LMcode-cli/tree/main/packages/config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lyin01/LMcode-cli.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/Lyin01/LMcode-cli/issues"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown && node -e \"require('fs').copyFileSync('dist/index.d.mts','dist/index.d.ts')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\""
  }
}
