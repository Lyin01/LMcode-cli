{
  "name": "@lmcode-cli/migration-legacy",
  "version": "0.7.3",
  "description": "Migrate lmcode-cli (~/.lmcode/) data into lmcode (~/.lmcode/).",
  "license": "MIT",
  "type": "module",
  "private": true,
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lmcode-cli/agent-core": "workspace:^",
    "pathe": "^2.0.3",
    "smol-toml": "^1.6.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lmcode-cli/jian": "workspace:^"
  }
}
