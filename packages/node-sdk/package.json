{
  "name": "@lmcode-cli/lmcode-sdk",
  "version": "0.7.3",
  "private": true,
  "description": "TypeScript SDK for the LMcode Agent",
  "license": "MIT",
  "author": "LMcode",
  "homepage": "https://github.com/Lyin01/LMcode-cli/tree/main/packages/node-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lyin01/LMcode-cli.git",
    "directory": "packages/node-sdk"
  },
  "bugs": {
    "url": "https://github.com/Lyin01/LMcode-cli/issues"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown && pnpm run build:dts",
    "build:dts": "node scripts/build-dts.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .tmp-api-extractor"
  },
  "dependencies": {
    "@antfu/utils": "^9.3.0",
    "smol-toml": "^1.6.1",
    "yazl": "^3.3.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lmcode-cli/agent-core": "workspace:^",
    "@lmcode-cli/config": "workspace:^",
    "@lmcode-cli/jian": "workspace:^",
    "@lmcode-cli/ltod": "workspace:^",
    "@types/yazl": "^2.4.6"
  }
}
