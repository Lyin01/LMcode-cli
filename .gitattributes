# Normalize line endings across platforms.
# Default: auto-detect text files and check them out with LF.
* text=auto eol=lf

# Shell scripts must stay LF (run on macOS/Linux and Git Bash).
*.sh text eol=lf

# Windows scripts must stay CRLF.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files: never normalize.
*.png binary
*.ico binary
*.zip binary
*.woff binary
*.woff2 binary
